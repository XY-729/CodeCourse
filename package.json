{
  "name": "codecourse-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "CodeCourse desktop shell for the GitHub project learner.",
  "main": "electron/main.cjs",
  "scripts": {
    "desktop:dev": "node electron/dev-runner.cjs",
    "desktop:build": "npm --prefix frontend run build && electron-builder",
    "desktop:pack": "npm --prefix frontend run build && electron-builder --dir",
    "frontend:build": "npm --prefix frontend run build",
    "backend:test": "cd backend && PYTHONPATH=.. .venv/bin/python -m unittest discover -s tests -v"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.codecourse.app",
    "productName": "CodeCourse",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "app/**/*",
          "requirements.txt"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "dir"
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
