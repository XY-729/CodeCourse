{
  "name": "codecourse-desktop",
  "version": "0.2.2",
  "private": true,
  "description": "CodeCourse desktop shell for the GitHub project learner.",
  "main": "electron/main.cjs",
  "scripts": {
    "desktop:dev": "node electron/dev-runner.cjs",
    "backend:build": "pyinstaller --noconfirm --clean --distpath dist-backend --workpath build/pyinstaller backend/backend.spec",
    "desktop:build": "npm run frontend:build && npm run backend:build && electron-builder",
    "desktop:pack": "npm run frontend:build && npm run backend:build && electron-builder --dir",
    "desktop:portable": "npm run frontend:build && npm run backend:build && electron-builder --win portable",
    "frontend:build": "npm --prefix frontend run build",
    "backend:test": "cd backend && PYTHONPATH=.. .venv/bin/python -m unittest discover -s tests -v"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.codecourse.app",
    "productName": "CodeCourse",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "win": {
      "artifactName": "${productName}-${version}-${os}-${arch}-portable.${ext}",
      "target": [
        "nsis",
        "portable"
      ],
      "extraResources": [
        {
          "from": "dist-backend/backend.exe",
          "to": "backend/backend.exe"
        },
        {
          "from": "resources/git",
          "to": "git"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "dir"
      ],
      "category": "Development",
      "extraResources": [
        {
          "from": "backend",
          "to": "backend",
          "filter": [
            "app/**/*",
            "requirements.txt"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
